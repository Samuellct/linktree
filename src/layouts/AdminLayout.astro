---
import '../styles/global.css';

interface Props {
  title?: string;
  activeTab?: 'dashboard' | 'links' | 'settings';
}

const { title = "Administration", activeTab } = Astro.props;
const user = Astro.locals.user;
---

<!DOCTYPE html>
<html lang="fr" class="h-full bg-slate-950">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    <title>{title} | Admin Panel</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="h-full font-sans text-slate-100 antialiased bg-slate-950">
    <div class="flex h-full min-h-screen">
      
      <!-- Sidebar Navigation -->
      <aside class="hidden md:flex md:w-64 md:flex-col md:fixed md:inset-y-0 border-r border-slate-800 bg-slate-900/60 backdrop-blur-md">
        <div class="flex-1 flex flex-col min-h-0">
          
          <!-- Brand Logo -->
          <div class="flex items-center h-16 flex-shrink-0 px-6 border-b border-slate-800">
            <span class="text-xl font-bold bg-gradient-to-r from-indigo-400 to-violet-400 bg-clip-text text-transparent">Linktree Admin</span>
          </div>

          <!-- Nav Items -->
          <nav class="flex-1 px-4 py-6 space-y-1">
            <a 
              href="/admin/dashboard" 
              class={`flex items-center px-4 py-3 text-sm font-medium rounded-xl transition-all duration-200 ${
                activeTab === 'dashboard' 
                  ? 'bg-indigo-600 text-white shadow-lg shadow-indigo-500/10' 
                  : 'text-slate-400 hover:bg-slate-800/50 hover:text-white'
              }`}
            >
              <svg class="mr-3 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
              Tableau de bord
            </a>

            <a 
              href="/admin/links" 
              class={`flex items-center px-4 py-3 text-sm font-medium rounded-xl transition-all duration-200 ${
                activeTab === 'links' 
                  ? 'bg-indigo-600 text-white shadow-lg shadow-indigo-500/10' 
                  : 'text-slate-400 hover:bg-slate-800/50 hover:text-white'
              }`}
            >
              <svg class="mr-3 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
              </svg>
              Gestion des liens
            </a>

            <a 
              href="/admin/settings" 
              class={`flex items-center px-4 py-3 text-sm font-medium rounded-xl transition-all duration-200 ${
                activeTab === 'settings' 
                  ? 'bg-indigo-600 text-white shadow-lg shadow-indigo-500/10' 
                  : 'text-slate-400 hover:bg-slate-800/50 hover:text-white'
              }`}
            >
              <svg class="mr-3 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              Configuration
            </a>
          </nav>

          <!-- Footer/User Info -->
          <div class="flex-shrink-0 flex border-t border-slate-800 p-4 bg-slate-950/20">
            <div class="flex-1 group block">
              <div class="flex items-center">
                <div class="inline-block h-9 w-9 rounded-full bg-slate-800 flex items-center justify-center text-indigo-400 font-semibold border border-indigo-500/20">
                  {user?.email ? user.email[0].toUpperCase() : 'A'}
                </div>
                <div class="ml-3">
                  <p class="text-sm font-medium text-white truncate max-w-[130px]">{user?.email}</p>
                  <button id="logoutBtn" class="text-xs font-medium text-red-400 hover:text-red-300 transition-colors">Déconnexion</button>
                </div>
              </div>
            </div>
          </div>

        </div>
      </aside>

      <!-- Main Layout -->
      <div class="md:pl-64 flex flex-col flex-1 w-full min-w-0">
        
        <!-- Mobile Topbar -->
        <header class="flex md:hidden items-center justify-between h-16 px-6 border-b border-slate-800 bg-slate-900/60 backdrop-blur-md sticky top-0 z-50">
          <span class="text-lg font-bold bg-gradient-to-r from-indigo-400 to-violet-400 bg-clip-text text-transparent">Linktree Admin</span>
          
          <div class="flex items-center gap-4">
            <nav class="flex gap-2">
              <a href="/admin/dashboard" class={`p-2 rounded-lg ${activeTab === 'dashboard' ? 'bg-indigo-600 text-white' : 'text-slate-400'}`} title="Tableau de bord">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                </svg>
              </a>
              <a href="/admin/links" class={`p-2 rounded-lg ${activeTab === 'links' ? 'bg-indigo-600 text-white' : 'text-slate-400'}`} title="Gestion des liens">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
                </svg>
              </a>
              <a href="/admin/settings" class={`p-2 rounded-lg ${activeTab === 'settings' ? 'bg-indigo-600 text-white' : 'text-slate-400'}`} title="Configuration">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                </svg>
              </a>
            </nav>
            <button id="mobileLogoutBtn" class="text-slate-400 hover:text-red-400 transition-colors" title="Déconnexion">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
              </svg>
            </button>
          </div>
        </header>

        <!-- Main Content Area -->
        <main class="flex-1 py-8 px-6 md:px-8">
          <slot />
        </main>
      </div>

    </div>

    <!-- Script to handle logout -->
    <script>
      const handleLogout = async () => {
        try {
          const res = await fetch('/api/auth', { method: 'DELETE' });
          if (res.ok) {
            window.location.href = '/admin/login';
          } else {
            alert('Erreur lors de la déconnexion');
          }
        } catch (e) {
          console.error(e);
        }
      };

      document.getElementById('logoutBtn')?.addEventListener('click', handleLogout);
      document.getElementById('mobileLogoutBtn')?.addEventListener('click', handleLogout);
    </script>
  </body>
</html>
