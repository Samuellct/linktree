---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { LinkEditor } from '../../components/admin/LinkEditor';
import { getAllLinks, getDb } from '../../lib/db';

const db = getDb();

// Fetch links from database
const links = db ? await getAllLinks(db) : [];
---

<AdminLayout title="Gestion des liens" activeTab="links">
  <LinkEditor client:load initialLinks={links} />
</AdminLayout>
