---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { DashboardStats } from '../../components/admin/DashboardStats';
import { getAnalyticsStats, getSettings, getDb } from '../../lib/db';

const db = getDb();

// Fetch settings for Umami configuration
const settings = db ? await getSettings(db) : {};

// Fetch analytics statistics (last 30 days default)
const stats = db ? await getAnalyticsStats(db) : {
  totalVisits: 0,
  uniqueVisitors: 0,
  totalClicks: 0,
  clicksPerLink: [],
  visitsOverTime: [],
  clicksOverTime: [],
  devices: [],
  browsers: [],
  countries: [],
};
---

<AdminLayout title="Tableau de bord" activeTab="dashboard">
  <DashboardStats 
    client:load 
    stats={stats} 
    umamiUrl={settings.umami_url} 
    umamiId={settings.umami_id} 
  />
</AdminLayout>
